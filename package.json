{
  "name": "esm-itter",
  "version": "1.1.1",
  "description": "ESMitter is a fork of the popular EventEmitter3 with a focus on EcmaScript module syntax, TypeScript and modern tooling.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "benchmark": "find benchmarks/run -name '*.js' -exec benchmarks/start.sh {} \\;",
    "compare": "node --experimental-strip-types --no-warnings benchmarks/compare.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "prettier": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/tillsanders/esm-itter.git"
  },
  "homepage": "https://tillsanders.github.io/esm-itter/",
  "keywords": [
    "EventEmitter",
    "EventEmitter2",
    "EventEmitter3",
    "ESMitter",
    "Events",
    "addEventListener",
    "addListener",
    "emit",
    "emits",
    "emitter",
    "event",
    "once",
    "pub/sub",
    "publish",
    "reactor",
    "subscribe",
    "deno",
    "jsr"
  ],
  "author": "Till Sanders",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tillsanders/esm-itter/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  }
}
